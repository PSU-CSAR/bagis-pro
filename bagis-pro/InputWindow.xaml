<Window x:Class="bagis_pro.InputWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:bagis_pro"
        mc:Ignorable="d"
        Title="InputWindow" Height="175" Width="350">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>
        <StackPanel Margin="10" Grid.Row="0">
            <Label Name="PromptLabel" Content="Enter your name:"/>
            <!-- Name the TextBox to access it in C# -->
            <TextBox Name="InputTextBox" Width="275" HorizontalAlignment="Left"/>
        </StackPanel>
        <StackPanel  Margin="10" Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Margin="0,10,0,0"  Width="50" Height="25" Click="CancelButton_Click"/>
            <Button Content="OK" Margin="10 ,10,0,0"  Width="50" Height="25" Click="OkButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
